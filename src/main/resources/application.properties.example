# Application
spring.application.name=QuantityMeasurementApp

# MySQL Database
spring.datasource.url=jdbc:mysql://localhost:3306/quantity_measurement_db
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.username=root
spring.datasource.password=yourpassword

# JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.open-in-view=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect

# Google OAuth2
spring.security.oauth2.client.registration.google.client-id=your-client-id
spring.security.oauth2.client.registration.google.client-secret=your-client-password
spring.security.oauth2.client.registration.google.scope=email,profile

# JWT
jwt.secret=ThisIsAVeryLongSecretKeyThatIsAtLeast32CharsLong!
jwt.expiration=86400000